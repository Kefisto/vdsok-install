AddReg             = DCB.reg, QOS.reg, Sriov.reg, ENCAP.reg, VMQ.reg, VRSS.reg
AddReg             = CoInKPM.reg
CopyFiles          = CopyFiles, MessageDll.CopyFiles
*IfType            = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType         = 0     ; NdisMedium802_3
*PhysicalMediaType = 14    ; NdisPhysicalMedium802_3

[F37CEPME.Server2022.Services]
AddService         = %ServiceName%, 2, ServerService, EventLog

[F37CEPME.Server2022.HW]
Include            = pci.inf
Needs              = PciSriovSupported.HW, PciIoSpaceNotRequired.HW
AddReg             = MSI.reg

[F37CEPME.Server2025]
Characteristics    = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType            = 5 ; PCI
DelReg             = Advanced.DelReg, ReceiveScalingMode.DelReg, RSC.Delreg
AddReg             = Default.reg, RSS.reg, FlowControl_Server.reg, LinkOnIntDown.reg, Uninstall.reg
Addreg             = PowermgmtEn.reg
AddReg             = NdisPoll.reg
AddReg             = RDMA.reg, NDKMODE3.reg, VLANID.reg
AddReg             = DCB.reg, QOS.reg, Sriov.reg, ENCAP.reg, VMQ.reg, VRSS.reg
AddReg             = CoInKPM.reg
CopyFiles          = CopyFiles, MessageDll.CopyFiles
*IfType            = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType         = 0     ; NdisMedium802_3
*PhysicalMediaType = 14    ; NdisPhysicalMedium802_3

[F37CEPME.Server2025.Services]
AddService         = %ServiceName%, 2, Win_Build_25398.Service, EventLog

[F37CEPME.Server2025.HW]
