HKR,Prounstl\SupportedDevices\8086, 37CF, 0, "37CF"
HKR,Prounstl\SupportedDevices\8086, 37D0, 0, "37D0"
HKR,Prounstl\SupportedDevices\8086, 37D1, 0, "37D1"
HKR,Prounstl\SupportedDevices\8086, 37D2, 0, "37D2"
HKR,Prounstl\SupportedDevices\8086, 37D3, 0, "37D3"
HKR,Prounstl\SupportedDevices\8086, 37CC, 0, "37CC"
HKR,Prounstl\Services, %ServiceName%, 0, i40eb.sys

;-----------------------------------------------------------------------------
; Driver "service" installation settings
;-----------------------------------------------------------------------------
[CommonService]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %13%\i40eb.sys
LoadOrderGroup = NDIS
AddReg         = Service_AddReg
DelReg         = DmaRemappingCompatible.DelReg
Addreg         = DmaRemappingCompatible.AddReg

[Service_AddReg]
HKR, Parameters, BootFlags, 0x00010001, 0x1

[Win_Build_25398.Service]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %13%\i40eb.sys
LoadOrderGroup = NDIS
DelReg         = DmaRemappingCompatible.DelReg
Addreg         = DmaRemappingCompatible.AddReg
BootFlags      = 0x1 ; CM_SERVICE_NETWORK_BOOT_LOAD

[DmaRemappingCompatible.DelReg]
HKR, Parameters, DmaRemappingCompatible

[DmaRemappingCompatible.AddReg]
HKR, Parameters, DmaRemappingCompatible, 0x00010001, 0

;-----------------------------------------------------------------------------
; Event Log settings
;-----------------------------------------------------------------------------
[EventLog]
AddReg = AddEventLog

[CoInK.reg]
HKR,, CoInstallFlag, 0x00010001, 0x20680040

[CoInKPM.reg]
HKR,, CoInstallFlag, 0x00010001, 0x20680048

[CoInKPMNoIov.reg]
HKR,, CoInstallFlag, 0x00010001, 0x00680048

[CopyFiles]
i40eb.sys,,,2

[MessageDll.CopyFiles]
i40ebmsg.dll,,,2

