; ------------------------------------------------------
; Intel(R) 200 Gigabit Controller
; ------------------------------------------------------
[F12DEOCPSFP25GPM]
Characteristics     = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType             = 5 ; PCI
Port1FunctionNumber = 0
DelReg              = Advanced.DelReg
DMA_DELREG
AddReg              = Default.reg, RSS.reg, VLANID.reg, Uninstall.reg
AddReg              = RDMA.reg, NDKMODE3.reg, DCB.reg, QOS.reg, Sriov.reg, ENCAP.reg, VMQ.reg, VRSS.reg, FWLOGGING.reg, Uso.reg
Addreg              = 1Gb_10Gb_25Gb_Speed.reg
Addreg              = Powermgmt.reg
Addreg              = FecMode.reg
AddReg              = CoInK.reg
CopyFiles           = CopyFiles, MessageDll.CopyFiles, Uninstall.CopyFiles
*IfType             = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType          = 0     ; NdisMedium802_3
*PhysicalMediaType  = 14    ; NdisPhysicalMedium802_3

[F12DEOCPSFP25GPM.Services]
AddService = %ServiceName%, 2, Service, EventLog

[F12DEOCPSFP25GPM.HW]
Include = pci.inf
Needs   = PciSriovSupported.HW, PciIoSpaceNotRequired.HW
AddReg  = MSI.reg

