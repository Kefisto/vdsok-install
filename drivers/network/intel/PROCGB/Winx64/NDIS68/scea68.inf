[Manufacturer]
%Intel% = Intel, NTamd64.10.0

[Intel]

[Intel.NTamd64.10.0]
; DisplayName                       Section  DeviceID
; -----------                       -------  --------
%F10A6.Generic.Description%       = NO_DRV,  PCI\VEN_8086&DEV_10A6
%F124C.Generic.Description%       = F124CPM, PCI\VEN_8086&DEV_124C
%F124D.Generic.Description%       = F124DPM, PCI\VEN_8086&DEV_124D
%F124E.Generic.Description%       = F124EPM, PCI\VEN_8086&DEV_124E
%F124F.Generic.Description%       = F124FPM, PCI\VEN_8086&DEV_124F
%F151D.Generic.Description%       = F151DPM, PCI\VEN_8086&DEV_151D
