[F579CPM.Server2022]
Characteristics     = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType             = 5 ; PCI
Port1FunctionNumber = 0
DelReg              = Advanced.DelReg
DelReg              = SpdDuplex.DelRegBP
AddReg              = Default.reg, RSS.reg, Uninstall.reg
AddReg              = VLANID.reg
AddReg              = DCB.reg, ENCAP.reg, FWLOGGING.reg, QOS.reg, Sriov.reg, Timestamp.reg, Uso.reg, VMQ.reg, VRSS.reg
AddReg              = HwQos.reg
Addreg              = Powermgmt.reg
Addreg              = FecMode.reg
AddReg              = CoInKPM.reg
CopyFiles           = CopyFiles, MessageDll.CopyFiles
*IfType             = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType          = 0     ; NdisMedium802_3
*PhysicalMediaType  = 14    ; NdisPhysicalMedium802_3

[F579CPM.Server2022.Services]
AddService          = %ServiceName%, 2, Service, EventLog

[F579CPM.Server2022.HW]
