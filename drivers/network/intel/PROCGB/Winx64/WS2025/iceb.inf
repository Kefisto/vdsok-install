;-----------------------------------------------------------------------------
; Driver "service" installation settings
;-----------------------------------------------------------------------------
[Service]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %13%\iceb.sys
LoadOrderGroup = NDIS
AddReg         = Service_AddReg
DelReg         = DmaRemappingCompatible.DelReg
Addreg         = DmaRemappingCompatible.AddReg

[Service_AddReg]
HKR, Parameters, BootFlags, 0x00010001, 0x1

[Win.10.0...25398.Service]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %13%\iceb.sys
LoadOrderGroup = NDIS
DelReg         = DmaRemappingCompatible.DelReg
Addreg         = DmaRemappingCompatible.AddReg
BootFlags      = 0x1 ; CM_SERVICE_NETWORK_BOOT_LOAD

[DmaRemappingCompatible.DelReg]
HKR, Parameters, DmaRemappingCompatible

[DmaRemappingCompatible.AddReg]
HKR, Parameters, DmaRemappingCompatible, 0x00010001, 0

