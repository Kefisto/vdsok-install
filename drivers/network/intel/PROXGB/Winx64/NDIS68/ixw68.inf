HKR,Prounstl\Services, %ServiceName%, 0, ixw68.sys

;-----------------------------------------------------------------------------
; Driver "service" installation settings
;-----------------------------------------------------------------------------
[Service]
DisplayName    = %Service.Displayname%
ServiceType    = 1 ;%SERVICE_KERNEL_DRIVER%
StartType      = 3 ;%SERVICE_DEMAND_START%
ErrorControl   = 1 ;%SERVICE_ERROR_NORMAL%
ServiceBinary  = %12%\ixw68.sys
LoadOrderGroup = NDIS
AddReg         = Service_AddReg
DelReg         = DmaRemappingCompatible.DelReg
Addreg         = DmaRemappingCompatible.AddReg

[Service_AddReg]
HKR, Parameters, BootFlags, 0x00010001, 0x1

[DmaRemappingCompatible.DelReg]
HKR, Parameters, DmaRemappingCompatible

[DmaRemappingCompatible.AddReg]
HKR, Parameters, DmaRemappingCompatible, 0x00010001, 0

;-----------------------------------------------------------------------------
; Event Log settings
;-----------------------------------------------------------------------------
[EventLog]
AddReg = AddEventLog

[CoInKPM.reg]
HKR,, CoInstallFlag, 0x00010001, 0x00280008

[MessageDll.CopyFiles]
ixwmsg.dll,,,2

[Uninstall.CopyFiles]
ixw68.din,,,2

[CopyFiles]
ixw68.sys,,,2

;-----------------------------------------------------------------------------
; DestinationDirs
;-----------------------------------------------------------------------------
[DestinationDirs]
CopyFiles            = 12
DefaultDestDir       = 11
MessageDll.CopyFiles = 11
Uninstall.CopyFiles  = 11

[SourceDisksNames]
1 = %DiskName%,,,

;-----------------------------------------------------------------------------
; SourceDisksFiles
;-----------------------------------------------------------------------------
[SourceDisksFiles]
ixw68.sys  = 1
ixwmsg.dll = 1
ixw68.din  = 1

