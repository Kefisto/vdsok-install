BusType            = 5 ; PCI
AddReg             = Default.reg, FlowControl_Client.reg, LinkSpeed.reg, IntelANSVlanID.reg,  DMACoalescing.reg, Uninstall.reg
AddReg             = IPSec.reg
AddReg             = CoInKPM.reg
CopyFiles          = CopyFiles, MessageDll.CopyFiles
*IfType            = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType         = 0     ; NdisMedium802_3
*PhysicalMediaType = 14    ; NdisPhysicalMedium802_3

