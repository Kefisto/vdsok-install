[NO_DRV.Services]
Include = machine.inf
Needs   = NO_DRV.Services

; ---------------------------------------------------
; Intel(R) Ethernet Controller E610 for 2.5GBASE-T
; ---------------------------------------------------
[W57B1_Client]
Characteristics     = 0x84 ; NCF_HAS_UI | NCF_PHYSICAL
BusType             = 5 ; PCI
Port1FunctionNumber = 0 
AddReg              = Default.reg, FlowControl.reg, Uninstall.reg
Addreg              = 2500Mb_Speed.reg
AddReg              = CoInKPM.reg
CopyFiles           = CopyFiles, MessageDll.CopyFiles
Addreg              = EEE.reg
*IfType             = 6     ; IF_TYPE_ETHERNET_CSMACD
*MediaType          = 0     ; NdisMedium802_3
*PhysicalMediaType  = 14    ; NdisPhysicalMedium802_3

[W57B1_Client.Services]
AddService = %ServiceName%, 2, Service, EventLog

[W57B1_Client.HW]
Include = pci.inf
Needs   = PciIoSpaceNotRequired.HW
AddReg  = MSI.reg

